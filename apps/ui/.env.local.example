# copy&rename to .env.local

# Do not leave empty values, e.g. `NEXT_OUTPUT=`, as it is interpreted as an empty string and
# default values won't be used. If you want to fallback to default values, remove or comment the line completely.

# -------------------------- Next.js settings ---------------------------------

# See next.config.js's "output" option. Possible values:
# - "standalone" - docker container
# - "export" - static export
# - undefined - default, `next start`
NEXT_OUTPUT=standalone

# Enable logging of generateStaticParams output during build time by segment
# DEBUG_STATIC_PARAMS_GENERATION=true

# Enable showing of non-blocking errors in the UI (very chattery logs)
# SHOW_NON_BLOCKING_ERRORS=true

# Enable logging of Strapi Client API calls (very chattery logs)
# DEBUG_STRAPI_CLIENT_API_CALLS=true

# -------------------------- BetterAuth settings ---------------------------------

# Can be generated in set enviroment variables section
BETTER_AUTH_SECRET=password_secret_password_secret_password_secret_password_secret

# -------------------------- BE settings ---------------------------------

# URL of Strapi
STRAPI_URL=http://127.0.0.1:1337

# Read Only API KEY generated within Strapi, providing access to find and findOne endpoints
STRAPI_REST_READONLY_API_KEY=

# API KEY with custom permissions, providing different access to Strapi endpoints
STRAPI_REST_CUSTOM_API_KEY=

# -------------------------- Sentry settings ---------------------------------

# Sentry DSN
# NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token
# SENTRY_AUTH_TOKEN=

# Sentry organization
# SENTRY_ORG=

# Sentry project
# SENTRY_PROJECT=

SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1

# -------------------------- Observability -----------------------------------
# Structured logging (@repo/logging). See docs/reference/integrations/logging.

# Log verbosity: trace | debug | info | warn | error | fatal | silent (default info)
# LOG_LEVEL=info

# OpenTelemetry service name attached to logs and spans (default "ui").
# OTEL_SERVICE_NAME=ui

# Optional — Azure Monitor / Application Insights telemetry provider (the
# bundled example). Leave unset to keep telemetry export inert (logs still go
# to stdout). See docs/reference/integrations/logging.
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# -------------------------- ReCAPTCHA v3 ---------------------------------

# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# RECAPTCHA_SECRET_KEY=

# -------------------------- Basic Auth ---------------------------------

# Enable HTTP Basic Authentication (e.g. for staging environments)
# BASIC_AUTH_ENABLED=true
# BASIC_AUTH_USERNAME=
# BASIC_AUTH_PASSWORD=

# -------------------------- App settings ---------------------------------

# canonical URL of site - base URL of the frontend application
# (it is used to navigate, generate sitemap URLs, canonical SEO tags etc.)
APP_PUBLIC_URL=http://localhost:3000

# Components and functions that are not *marked as used* will log a warning to the console during development by default.
# To change this behavior, set this env var to `true`.
# NEXT_PUBLIC_PREVENT_UNUSED_FUNCTIONS_ERROR_LOGS=true

# Strapi Preview Shared Secret
STRAPI_PREVIEW_SECRET=your-secret-key

# -------------------------- imgproxy ---------------------------------

# Base URL of a self-hosted imgproxy instance (enables on-the-fly image resizing & retina support)
# IMGPROXY_URL=https://imgproxy.example.com

# -------------------------- Cache revalidation + CDN purge ---------------------------------

# Bearer secret authenticating cache revalidation requests from Strapi.
# Must match STRAPI_REVALIDATE_SECRET in apps/strapi.
STRAPI_REVALIDATE_SECRET=

# Bearer secret authenticating CDN purge requests from Strapi.
# Must match STRAPI_CDN_PURGE_SECRET in apps/strapi.
STRAPI_CDN_PURGE_SECRET=

# Optional — Azure Front Door CDN purge provider (the bundled example).
# Leave unset to keep the CDN purge feature inert. See
# docs/reference/integrations/cdn-purge.
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
# AZURE_FRONT_DOOR_PROFILE=
# AZURE_MI_CLIENT_ID=
# IDENTITY_ENDPOINT and IDENTITY_HEADER are injected by the Azure Container App runtime.