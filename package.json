{
  "name": "strapi-next-monorepo-starter",
  "version": "3.0.0",
  "private": true,
  "author": {
    "name": "Notum Technologies",
    "email": "info@notum.cz",
    "url": "https://notum.cz"
  },
  "maintainers": [
    {
      "name": "Notum Technologies",
      "email": "info@notum.cz",
      "url": "https://notum.cz"
    }
  ],
  "scripts": {
    "build": "turbo build --cache-dir=.turbo",
    "build:docs": "pnpm -F @repo/docs build",
    "build:strapi": "turbo run build --filter=@repo/strapi",
    "build:ui": "turbo run build --filter=@repo/ui",
    "build:ui:static": "NODE_OPTIONS=--max-old-space-size=2048 turbo run build:static --filter=@repo/ui",
    "commit": "git-cz",
    "dev": "turbo dev",
    "dev:docs": "pnpm -F @repo/docs start",
    "dev:strapi": "turbo run dev --filter=@repo/strapi",
    "dev:ui": "turbo run dev --filter=@repo/ui",
    "format": "prettier --write --cache --ignore-unknown \"**/(*.{md,css,scss}|*.package.json)\"",
    "format:check": "prettier --check --cache --ignore-unknown \"**/(*.{md,css,scss}|*.package.json)\"",
    "generate:types": "turbo run generate:types --filter=@repo/strapi",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm run setup:apps",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "prepare": "if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then lefthook install --reset-hooks-path; else echo 'Skipping lefthook install: not inside a Git worktree.'; fi",
    "run:db": "turbo run run:db --filter=@repo/strapi",
    "run:imgproxy": "turbo run run:imgproxy --filter=@repo/strapi",
    "seed:check": "turbo run seed:check --filter=@repo/strapi",
    "seed:export": "turbo run seed:export --filter=@repo/strapi",
    "seed:import": "turbo run seed:import --filter=@repo/strapi",
    "setup:apps": "find . -name '*.example' -exec sh -c 'cp -n \"$1\" \"${1%.example}\"' _ {} \\;",
    "start:docs": "pnpm -F @repo/docs serve",
    "start:strapi": "turbo run start --filter=@repo/strapi",
    "start:ui": "turbo run start --filter=@repo/ui",
    "sync-types": "turbo run sync-types --filter=@repo/strapi-types",
    "test": "turbo run test",
    "test:ci": "turbo run test",
    "test:strapi": "turbo run test --filter=@repo/strapi",
    "test:ui": "turbo run test --filter=@repo/ui",
    "tests:lhci:perfo": "turbo run lhci-perfo-check --filter=@repo/tests-playwright",
    "tests:playwright:axe": "turbo run axe-test --filter=@repo/tests-playwright",
    "tests:playwright:e2e:test": "turbo run playwright-e2e-tests --filter=@repo/tests-playwright",
    "tests:playwright:e2e:test:interactive": "turbo run playwright-interactive-mode --filter=@repo/tests-playwright",
    "tests:playwright:seo": "turbo run playwright-seo-tests --filter=@repo/tests-playwright",
    "tests:playwright:visual": "turbo run playwright-visual-tests --filter=@repo/tests-playwright",
    "tests:playwright:visual:docker": "turbo run playwright-visual-tests-docker --filter=@repo/tests-playwright",
    "tests:playwright:visual:docker:update": "turbo run playwright-visual-update-snapshots-docker --filter=@repo/tests-playwright",
    "tests:playwright:visual:update": "turbo run playwright-visual-update-tests --filter=@repo/tests-playwright",
    "transfer:strapi": "turbo run transfer --filter=@repo/strapi",
    "typecheck": "turbo run typecheck",
    "typecheck:strapi": "turbo run typecheck --filter=@repo/strapi",
    "typecheck:ui": "turbo run typecheck --filter=@repo/ui",
    "worktree:cleanup": "scripts/worktree/cleanup.sh",
    "worktree:create": "scripts/worktree/create.sh",
    "worktree:setup": "scripts/worktree/setup.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@commitlint/config-pnpm-scopes": "20.5.2",
    "@repo/eslint-config": "workspace:*",
    "@repo/semantic-release-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "commitizen": "4.3.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.39.4",
    "lefthook": "2.1.9",
    "lint-staged": "15.5.2",
    "prettier": "3.8.4",
    "semantic-release": "24.2.9",
    "tslib": "2.8.1",
    "turbo": "2.9.18"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": "^24.0.0"
  }
}
